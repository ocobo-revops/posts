{
  "name": "ocobo-posts",
  "version": "1.0.0",
  "description": "Content repository for Ocobo blog and stories",
  "type": "module",
  "scripts": {
    "upload-assets": "node --env-file-if-exists=.env scripts/upload-assets.js",
    "upload-assets:all": "node --env-file-if-exists=.env scripts/upload-assets.js --all",
    "upload-assets:migrate": "node --env-file-if-exists=.env scripts/upload-assets.js --all --target new",
    "update-urls": "node --env-file-if-exists=.env scripts/update-asset-urls.js",
    "update-urls:new": "node --env-file-if-exists=.env scripts/update-asset-urls.js --target new",
    "sync-assets": "pnpm upload-assets && pnpm update-urls",
    "sync-assets:all": "pnpm upload-assets:all && pnpm update-urls",
    "sync-assets:migrate": "pnpm upload-assets:migrate && pnpm update-urls:new",
    "optimize-assets": "node scripts/optimize-assets.js --changed",
    "optimize-assets:write": "node scripts/optimize-assets.js --changed --write",
    "validate": "node scripts/validate-content.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vercel/blob": "^1.1.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wab/ocobo-posts.git"
  },
  "author": "Ocobo",
  "license": "MIT"
}